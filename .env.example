# Скопіюйте цей файл у .env та заповніть реальними значеннями.
# Файл .env ІГНОРУЄТЬСЯ git (див. .gitignore) — ніколи не комітьте його.

# Варіант 1 — повний URL підключення (має перевагу):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Варіант 2 — окремі компоненти (використовуються, якщо DATABASE_URL не задано):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
